"""
Integration Tests for Socket.IO Real-Time Collaboration

Tests cover Socket.IO helper functions and their logic.
Tests the functions that are used by REST APIs.

Written for Phase 5 of Task 1.2: Socket.IO Integration
"""

import pytest
from unittest.mock import MagicMock, patch
from datetime import datetime

from app.api.socket_events import (
    sio_server,
    emit_task_created,
    emit_task_updated,
    emit_task_deleted,
    broadcast_crdt_update
)


@pytest.fixture
def mock_sio_server():
    """Create a mock Socket.IO server for testing."""
    mock_sio = MagicMock()
    return mock_sio


@pytest.mark.asyncio
class TestSocketIOHelpers:
    """Integration tests for Socket.IO helper functions."""

    # ========================================
    # A. Task Event Helper Functions (3 tests)
    # ========================================

    async def test_emit_task_created(self, mock_sio_server):
        """
        Test: emit_task_created broadcasts to workspace

        AAA Pattern:
        - Arrange: Setup task data and mock sio_server
        - Act: Patch sio_server, call emit_task_created
        - Assert: Broadcast to room with timestamp

        Success Criteria:
        - Function emits task_created event
        - Room targeting works
        - Timestamp added
        """
        # Arrange
        task_data = {
            "task_id": "task_123",
            "title": "New Test Task",
            "workspace_id": "ws_456",
            "user_id": "user_123"
        }

        # Mock global sio_server and patch to use mock
        with patch('app.api.socket_events.sio_server', mock_sio_server):
            # Act - Call emit_task_created
            emit_task_created(task_data)

            # Assert - Socket.IO broadcast called
            mock_sio_server.emit.assert_called_once()
            call_args = mock_sio_server.emit.call_args

            # Check event name
            assert call_args[0][0] == "task_created"

            # Check room
            assert call_args[1]["room"] == "ws_456"

            # Check data includes timestamp
            assert "created_at" in call_args[0][1]
            assert call_args[0][1]["task_id"] == "task_123"
            assert call_args[0][1]["title"] == "New Test Task"
            assert call_args[0][1]["workspace_id"] == "ws_456"
            assert call_args[0][1]["user_id"] == "user_123"

    async def test_emit_task_updated(self, mock_sio_server):
        """
        Test: emit_task_updated broadcasts to workspace

        AAA Pattern:
        - Arrange: Setup task data and mock sio_server
        - Act: Patch sio_server, call emit_task_updated
        - Assert: Broadcast to room

        Success Criteria:
        - Function emits task_updated event
        - Room targeting works
        - No timestamp added (not created event)
        """
        # Arrange
        task_data = {
            "task_id": "task_123",
            "title": "Updated Task Title",
            "workspace_id": "ws_789",
            "user_id": "user_456"
        }

        # Mock global sio_server and patch to use mock
        with patch('app.api.socket_events.sio_server', mock_sio_server):
            # Act - Call emit_task_updated
            emit_task_updated(task_data)

            # Assert - Socket.IO broadcast called
            mock_sio_server.emit.assert_called_once()
            call_args = mock_sio_server.emit.call_args

            # Check event name
            assert call_args[0][0] == "task_updated"

            # Check room
            assert call_args[1]["room"] == "ws_789"

            # Check data
            assert call_args[0][1]["task_id"] == "task_123"
            assert call_args[0][1]["title"] == "Updated Task Title"
            assert call_args[0][1]["workspace_id"] == "ws_789"
            assert call_args[0][1]["user_id"] == "user_456"

