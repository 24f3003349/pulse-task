    async def test_emit_task_created_handles_none_sio_server(self):
        """
        Test: Helper functions handle None sio_server gracefully

        AAA Pattern:
        - Arrange: Setup sio_server as None
        - Act: Call emit_task_created
        - Assert: No error raised

        Success Criteria:
        - Function returns without error
        - No broadcast attempted
        """
        # Arrange
        task_data = {
            "task_id": "task_123",
            "workspace_id": "ws_456"
            "user_id": "user_123"
        }

        # Mock sio_server as None
        with patch('app.api.socket_events.sio_server', None):
            # Act - Call emit_task_created
            # This should not raise an error
            result = emit_task_created(task_data)

            # Assert - Returns without error
            assert result is None

