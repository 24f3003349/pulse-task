    # ========================================
    # B. CRDT Event Helper Functions (3 tests)
    # ========================================

    async def test_broadcast_crdt_update(self, mock_sio_server):
        """
        Test: broadcast_crdt_update broadcasts to workspace

        AAA Pattern:
        - Arrange: Setup CRDT data and mock sio_server
        - Act: Patch sio_server, call broadcast_crdt_update
        - Assert: Broadcast to room with timestamp

        Success Criteria:
        - Function broadcasts to room
        - Room targeting works
        - Timestamp added
        """
        # Arrange
        workspace_id = "ws_222"
        crdt_data = {
            "doc_key": "ydoc_key_def",
            "list_id": "ws_222",
            "operation": "update",
            "user_id": "user_222",
            "content": "updated content"
        }

        # Mock global sio_server and patch to use mock
        with patch('app.api.socket_events.sio_server', mock_sio_server):
            # Act - Call broadcast_crdt_update
            broadcast_crdt_update(workspace_id, crdt_data)

            # Assert - Socket.IO broadcast called
            mock_sio_server.emit.assert_called_once()
            call_args = mock_sio_server.emit.call_args

            # Check event name
            assert call_args[0][0] == "crdt_update"

            # Check room
            assert call_args[1]["room"] == "ws_222"

            # Check data includes timestamp
            assert "updated_at" in call_args[0][1]
            assert call_args[0][1]["doc_key"] == "ydoc_key_def"
            assert call_args[0][1]["list_id"] == "ws_222"
            assert call_args[0][1]["operation"] == "update"
            assert call_args[0][1]["user_id"] == "user_222"
            assert call_args[0][1]["content"] == "updated content"

